module test_esp_nuc
    use PFUNIT
    use quick_oeproperies_module, only: esp_nuc
    use quick_molspec_module, only: natom, quick_molspec, xyz

    contains

    @before
    subroutine setup()
      implicit none

      natom=3
      allocate(quick_molspec%chg(natom))
      allocate(xyz(3,natom))

      xyz=[0.0,0.0,0.0,1.8,0.0,0.0,0.0,1.8,0.0]
      quick_molspec%chg=[8,1,1]

    end subroutine

    @test(#ifdef=UNITTEST)
    subroutine testing()
        implicit none
    
        integer, parameter:: npoints = 2
        double precision:: xyz_points(3,2), esp_nuclear(2)

        xyz_points=[2.0,2.0,0.0,2.0,-2.0,0.0]

        call esp_nuc(npoints, xyz_points, esp_nuclear)

        @assertEqual(esp_nuclear(1), 3.8234643, tolerance=0.000001, message='esp_nuc(1) value not correct')
        @assertEqual(esp_nuclear(2), 3.5588189, tolerance=0.000001, message='esp_nuc(2) value not correct')
    
    end subroutine

end module test_esp_nuc
