module test_esp_nuc
    use PFUNIT
    use quick_oeproperties_module, only: esp_nuc
    use quick_molspec_module, only: natom, quick_molspec, xyz

    contains

    @before
    subroutine setup()
      implicit none

      natom=3
      allocate(quick_molspec%chg(natom))
      allocate(xyz(3,natom))

      xyz=reshape([0.0,0.0,0.0,1.8,0.0,0.0,0.0,1.8,0.0],[3,natom])
      quick_molspec%chg=[8,1,1]

    end subroutine setup

    @test(#ifdef=UNITTEST)
    subroutine testing()
        implicit none
    
        integer, parameter:: npoints = 2
        double precision:: xyz_points(3,2), esp_nuclear(2)
        double precision, parameter:: tol = 1.0e-6
        double precision, parameter:: target_esp(2) = [3.8234643,3.5588189]

        xyz_points=reshape([2.0,2.0,0.0,2.0,-2.0,0.0],[3,npoints])

        call esp_nuc(npoints, xyz_points, esp_nuclear)

        @assertEqual(esp_nuclear(1), target_esp(1), tolerance=0.000001, message='esp_nuc(1) value not correct')
        @assertEqual(esp_nuclear(2), target_esp(2), tolerance=0.000001, message='esp_nuc(2) value not correct')
    
    end subroutine testing

end module test_esp_nuc
