module test_espgrid_spacing
    use PFUNIT
    use quick_molsurface_module, only: generate_MKS_surfaces
    use quick_molspec_module, only: natom, quick_molspec, xyz
    use quick_method_module, only: quick_method

    contains

    @before
    subroutine setup()
      implicit none

      natom=3
      allocate(quick_molspec%chg(natom))
      allocate(xyz(3,natom))

      xyz=reshape([0.0,0.0,0.0,1.79524,0.0,0.0,0.0,1.79524,0.0],[3,natom])
      quick_molspec%chg=[8,1,1]
      quick_method%vdw_radii = "BONDI"
      quick_method%espgrid_spacing = 0.75

    end subroutine setup

    @test(#ifdef=UNITTEST)
    subroutine testing()
        implicit none

        integer, parameter:: npoints = 620
        double precision, parameter:: tol = 1.0e-6
        double precision, parameter:: surface_points(5) = [-2.86088748325, -1.39493629379, -2.38643717751, -3.14267919974, 4.44885648294] 

        call generate_MKS_surfaces()

        @assertEqual(quick_molspec%nvdwpoint, npoints, message='no of points on van der waals surface not correct')

        @assertEqual(quick_molspec%vdwpointxyz(2,42), surface_points(1), tolerance=tol, message='1st tested vdwpointxyz not correct')
        @assertEqual(quick_molspec%vdwpointxyz(1,155), surface_points(2), tolerance=tol, message='2nd tested vdwpointxyz not correct')
        @assertEqual(quick_molspec%vdwpointxyz(3,234), surface_points(3), tolerance=tol, message='3rd tested vdwpointxyz not correct')
        @assertEqual(quick_molspec%vdwpointxyz(2,433), surface_points(4), tolerance=tol, message='4th tested vdwpointxyz not correct')
        @assertEqual(quick_molspec%vdwpointxyz(1,586), surface_points(5), tolerance=tol, message='5th tested vdwpointxyz not correct')
    
    end subroutine testing

    @after
    subroutine cleanup()

    deallocate(quick_molspec%vdwpointxyz)
    deallocate(quick_molspec%chg)
    deallocate(xyz)

    end subroutine cleanup

end module test_espgrid_spacing
